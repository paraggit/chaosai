{
  "_comment": {
    "_comment": "Catalog of krknctl scenarios. Each node needs depends_on (string) except the root. Run 'krknctl describe <name>' for env schema."
  },
  "root_5j6t5": {
    "image": "quay.io/krkn-chaos/krkn-hub:dummy-scenario",
    "name": "dummy-scenario",
    "env": {
      "END": "10",
      "EXIT_STATUS": "0"
    }
  },
  "application-outages_5j6t5": {
    "image": "quay.io/krkn-chaos/krkn-hub:application-outages",
    "name": "application-outages",
    "env": {
      "BLOCK_TRAFFIC_TYPE": "[Ingress, Egress]",
      "DURATION": "600",
      "NAMESPACE": "openshift-storage",
      "POD_SELECTOR": "{app: rook-ceph-mgr}",
      "WAIT_DURATION": "60",
      "KRKN_DEBUG": "False"
    },
    "depends_on": "root_5j6t5"
  },
  "container-scenarios_5j6t5": {
    "image": "quay.io/krkn-chaos/krkn-hub:container-scenarios",
    "name": "container-scenarios",
    "env": {
      "ACTION": "1",
      "CONTAINER_NAME": "",
      "DISRUPTION_COUNT": "1",
      "EXPECTED_RECOVERY_TIME": "60",
      "LABEL_SELECTOR": "app=rook-ceph-osd",
      "NAMESPACE": "openshift-storage"
    },
    "depends_on": "root_5j6t5"
  },
  "network-chaos_egress_5j6t5": {
    "image": "quay.io/krkn-chaos/krkn-hub:network-chaos",
    "name": "network-chaos",
    "env": {
      "DURATION": "300",
      "EGRESS": "{bandwidth: 100mbit}",
      "EXECUTION": "parallel",
      "INSTANCE_COUNT": "1",
      "LABEL_SELECTOR": "node-role.kubernetes.io/worker=",
      "TRAFFIC_TYPE": "egress",
      "WAIT_DURATION": "300"
    },
    "depends_on": "root_5j6t5"
  },
  "node-cpu-hog_5j6t5": {
    "image": "quay.io/krkn-chaos/krkn-hub:node-cpu-hog",
    "name": "node-cpu-hog",
    "env": {
      "NAMESPACE": "openshift-storage",
      "NODE_CPU_CORE": "2",
      "NODE_CPU_PERCENTAGE": "95",
      "NODE_SELECTOR": "node-role.kubernetes.io/worker=",
      "TOTAL_CHAOS_DURATION": "80"
    },
    "depends_on": "root_5j6t5"
  },
  "node-io-hog_5j6t5": {
    "image": "quay.io/krkn-chaos/krkn-hub:node-io-hog",
    "name": "node-io-hog",
    "env": {
      "IO_BLOCK_SIZE": "1m",
      "IO_WORKERS": "5",
      "IO_WRITE_BYTES": "10m",
      "NAMESPACE": "openshift-storage",
      "NODE_SELECTOR": "node-role.kubernetes.io/worker=",
      "TOTAL_CHAOS_DURATION": "60"
    },
    "depends_on": "root_5j6t5"
  },
  "node-memory-hog_5j6t5": {
    "image": "quay.io/krkn-chaos/krkn-hub:node-memory-hog",
    "name": "node-memory-hog",
    "env": {
      "MEMORY_CONSUMPTION_PERCENTAGE": "90%",
      "NAMESPACE": "openshift-storage",
      "NODE_SELECTOR": "node-role.kubernetes.io/worker=",
      "NUMBER_OF_WORKERS": "4",
      "TOTAL_CHAOS_DURATION": "80"
    },
    "depends_on": "root_5j6t5"
  },
  "node-network-filter_5j6t5": {
    "image": "quay.io/krkn-chaos/krkn-hub:node-network-filter",
    "name": "node-network-filter",
    "env": {
      "NODE_SELECTOR": "node-role.kubernetes.io/worker=",
      "NAMESPACE": "openshift-storage",
      "INSTANCE_COUNT": "1",
      "EXECUTION": "parallel",
      "INGRESS": "true",
      "EGRESS": "true",
      "PORTS": "8080,8443",
      "PROTOCOLS": "tcp",
      "TOTAL_CHAOS_DURATION": "60"
    },
    "depends_on": "root_5j6t5"
  },
  "pod-network-chaos_5j6t5": {
    "image": "quay.io/krkn-chaos/krkn-hub:pod-network-chaos",
    "name": "pod-network-chaos",
    "env": {
      "EGRESS_PORTS": "[]",
      "INGRESS_PORTS": "[]",
      "INSTANCE_COUNT": "1",
      "LABEL_SELECTOR": "app=rook-ceph-osd",
      "NAMESPACE": "openshift-storage",
      "TEST_DURATION": "120",
      "TRAFFIC_TYPE": "[ingress,egress]",
      "WAIT_DURATION": "300"
    },
    "depends_on": "root_5j6t5"
  },
  "pod-network-filter_5j6t5": {
  "image": "quay.io/krkn-chaos/krkn-hub:pod-network-filter",
  "name": "pod-network-filter",
  "env": {
    "NAMESPACE": "openshift-storage",
    "POD_SELECTOR": "app=rook-ceph-osd",
    "INSTANCE_COUNT": "1",
    "EXECUTION": "parallel",
    "INGRESS": "true",
    "EGRESS": "true",
    "PORTS": "8080,8443",
    "PROTOCOLS": "tcp",
    "TOTAL_CHAOS_DURATION": "60"
  },
  "depends_on": "root_5j6t5"
  },
  "pod-scenarios_5j6t5": {
    "image": "quay.io/krkn-chaos/krkn-hub:pod-scenarios",
    "name": "pod-scenarios",
    "env": {
      "DISRUPTION_COUNT": "1",
      "EXPECTED_RECOVERY_TIME": "120",
      "KILL_TIMEOUT": "180",
      "NAMESPACE": "openshift-storage",
      "NAME_PATTERN": ".*",
      "POD_LABEL": "app=rook-ceph-osd",
      "WAIT_DURATION": "1"
    },
    "depends_on": "root_5j6t5"
  },
  "service-disruption-scenarios_5j6t5": {
    "image": "quay.io/krkn-chaos/krkn-hub:service-disruption-scenarios",
    "name": "service-disruption-scenarios",
    "env": {
      "DELETE_COUNT": "1",
      "LABEL_SELECTOR": "app=rook-ceph-osd",
      "NAMESPACE": "openshift-storage",
      "RUNS": "1"
    },
    "depends_on": "root_5j6t5"
  }
}