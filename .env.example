# ── Cluster Access ──
KUBECONFIG=/path/to/kubeconfig

# ── Local LLM endpoint (Ollama, vLLM, llama.cpp, etc.) ──
LLM_ENDPOINT=http://localhost:11434
LLM_MODEL=granite3.1-dense:8b

# ── Tool Binaries ──
BOB_CLI_PATH=/usr/local/bin/bob
KRKNCTL_PATH=/usr/local/bin/krknctl
OC_PATH=oc

# ── Scenario Plan ──
SCENARIO_PLAN_PATH=./scenario_plan.json

# ── Timeouts (seconds) ──
CHAOS_TIMEOUT=600
CHAOS_POLL_INTERVAL=15

# ── Logging ──
LOG_LEVEL=INFO
