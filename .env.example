# ── Cluster Access ──
KUBECONFIG=/path/to/kubeconfig

# ── Local LLM endpoint (Ollama, vLLM, llama.cpp, etc.) ──
LLM_ENDPOINT=http://localhost:11434
LLM_MODEL=granite3.1-dense:8b

# ── Tool Binaries ──
BOB_CLI_PATH=/usr/local/bin/bob
KRKNCTL_PATH=/usr/local/bin/krknctl
# Retries when krknctl fails (e.g. "no release found", Quay/GitHub API flakes)
KRKNCTL_RETRIES=3
OC_PATH=oc

# ── Scenario Plan ──
SCENARIO_PLAN_PATH=./scenario_plan.json

# ── Executor (ToolCallingAgent) ──
# BeeAI default is 10; increase if steps fail with "not able to resolve in N iterations"
EXECUTOR_MAX_ITERATIONS=25

# ── Timeouts (seconds) ──
CHAOS_TIMEOUT=600
CHAOS_POLL_INTERVAL=15
# How long to wait after chaos is active before
# running operations (lets disruption take effect)
CHAOS_SETTLE_TIME=30
# Krknctl parallel workers in generated bash script (script mode)
CHAOS_MAX_PARALLEL=4

# ── Test Execution ──
# Number of iterations for test operations loop
LOOP_COUNT=10

# ── Post-run ──
COLLECT_MUST_GATHER=false

# ── Logging ──
# Console (stderr): INFO or DEBUG. Log file logs/run_*.log always includes DEBUG.
# CLI: --verbose forces DEBUG on stderr as well.
LOG_LEVEL=INFO

# ── RAG Pipeline (ocs-ci codebase) ──
# RAG_REPO_URL=https://github.com/red-hat-storage/ocs-ci.git
# RAG_REPO_LOCAL_PATH=./data/ocs-ci
# RAG_REPO_BRANCH=master
# RAG_PERSIST_DIR=./data/chroma_db
# RAG_COLLECTION=ocs_ci_codebase
# RAG_EMBED_MODEL=nomic-embed-text
# RAG_EMBED_URL=http://localhost:11434
# RAG_TOP_K=8
# RAG_SCORE_THRESHOLD=0.3
